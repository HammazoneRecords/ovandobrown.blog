# ============================================
# GITIGNORE — Book of Solobility
# Only the solob-portal gets GitHub'd.
# ============================================

# Ignore everything at root
/*

# Allow these essential git/repo files
!.gitignore
!.gitattributes
!README.md

# Allow the entire solob-portal directory
!solob-portal/

# Ignore build artifacts and deps INSIDE solob-portal
solob-portal/node_modules/
solob-portal/.next/
solob-portal/out/
solob-portal/.env
solob-portal/.env.local
solob-portal/.env*.local

# VPS backups — large, contains secrets, never commit
vps_management/backups/

# Extracted chat corpus — verbatim user + Claude messages from Claude Code,
# Cline, Copilot, VS Code chats. Generated by scripts/extract_chat_corpus.py.
# Redacted for known secret patterns but never commit anyway.
playground/2026-05-claude-md-overhaul/corpus/
